{
  "name": "strapi-provider-upload-tencent-cloud-storage",
  "version": "1.2.0",
  "description": "A integration of Tencent Cloud COS as a file storage solution within Strapi.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "directories": {
    "lib": "./lib"
  },
  "scripts": {
    "cz": "cz",
    "format": "prettier --write --ignore-unknown",
    "lint": "eslint .",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "release": "standard-version",
    "prepare": "husky install",
    "preinstall": "npx only-allow pnpm -y"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yclgkd/strapi-provider-upload-tencent-cloud-storage.git"
  },
  "keywords": [
    "strapi",
    "strapi-v4",
    "strapi-v5",
    "tencent-cos",
    "cos",
    "strapi-provider",
    "strapi-provider-upload",
    "object-storage"
  ],
  "author": {
    "name": "Brian Yao",
    "email": "me@brianyao.tech"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yclgkd/strapi-provider-upload-tencent-cloud-storage/issues"
  },
  "homepage": "https://github.com/yclgkd/strapi-provider-upload-tencent-cloud-storage#readme",
  "devDependencies": {
    "@commitlint/cli": "^17.7.0",
    "@commitlint/config-conventional": "^17.7.0",
    "@eslint/js": "^10.0.1",
    "@strapi/utils": "^5.43.0",
    "@types/node": "^20.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.0",
    "prettier": "3.0.2",
    "standard-version": "^9.5.0",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "cos-nodejs-sdk-v5": "^2.12.4"
  },
  "peerDependencies": {
    "@strapi/strapi": ">=4.0.0",
    "@strapi/utils": "^4 || ^5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
